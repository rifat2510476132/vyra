{
  "name": "vyra-server",
  "version": "1.0.0",
  "description": "Vyra social platform backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate --schema=prisma/schema.prisma",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "postinstall": "npm run prisma:generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "vyra",
    "social",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.6.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "nodemailer": "^6.9.16",
    "openai": "^5.3.0",
    "prisma": "^6.9.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^6.4.23",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
