# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080
APP_PUBLIC_URL=http://localhost:8080
# Optional: serve Flutter web build from API (path to build/web)
# WEB_ROOT=../client/build/web

# Optional SMTP (if empty, emails print to server console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VYRA <noreply@vyra.app>

# Database
DATABASE_URL=postgresql://postgres:1234@localhost:5432/vyra?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (server verifies idToken audience)
GOOGLE_CLIENT_ID=

# OpenAI
OPENAI_API_KEY=

# Firebase Admin (JSON string or path)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
